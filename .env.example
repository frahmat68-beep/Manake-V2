APP_NAME="Manake V2"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─────────────────────────────────────────────────────────────────────────────
# Supabase PostgreSQL Database
# Get credentials from: Supabase Dashboard → Project → Settings → Database
# Use the "Session mode" connection string (port 5432) for Laravel migrations
# ─────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_SSLMODE=require

# ─────────────────────────────────────────────────────────────────────────────
# Session / Cache / Queue — use database driver (no Redis needed on Vercel)
# ─────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─────────────────────────────────────────────────────────────────────────────
# Midtrans Payment Gateway
# Sandbox credentials: https://dashboard.sandbox.midtrans.com/
# Production credentials: https://dashboard.midtrans.com/
# Callback URL to register in Midtrans: https://YOUR_DOMAIN/midtrans/callback
# ─────────────────────────────────────────────────────────────────────────────
MIDTRANS_MERCHANT_ID=
MIDTRANS_CLIENT_KEY=
MIDTRANS_SERVER_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ─────────────────────────────────────────────────────────────────────────────
# Mail (Optional — for order confirmation emails)
# ─────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@manake.id"
MAIL_FROM_NAME="Manake"

# ─────────────────────────────────────────────────────────────────────────────
# Admin Seeder Credentials
# Used by DatabaseSeeder to create the default admin account safely
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

VITE_APP_NAME="${APP_NAME}"
